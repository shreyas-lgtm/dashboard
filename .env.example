# Zoho OAuth credentials — copy to .env and fill in your values
# Get these from https://api-console.zoho.com → Self Client
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# Your Zoho Organization ID (visible in any Zoho Procurement API response)
ZOHO_ORGANIZATION_ID=60068679686

# Zoho accounts domain — change to zoho.eu / zoho.in / zoho.com.au if needed
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com

# Set to "true" to use mock data instead of live API (useful for local dev)
VITE_USE_MOCK=false
